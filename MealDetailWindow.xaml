<Window x:Class="calcaot.MealDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="500" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,14"
                   Foreground="{DynamicResource PrimaryText}"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="FoodsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBackground}"
                                CornerRadius="10"
                                Margin="0,5"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               FontSize="15"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock FontSize="12"
                                               Foreground="{DynamicResource SecondaryText}">
                                        <Run Text="{Binding Weight, StringFormat={}{0:F0} г}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{Binding Calories, StringFormat={}{0:F0} ккал}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="SummaryText"
                   Grid.Row="2"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Right"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{DynamicResource SecondaryText}"/>
    </Grid>
</Window>
