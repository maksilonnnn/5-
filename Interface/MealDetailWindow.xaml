<Window x:Class="calcaot.MealDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="500" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}"
        Title="Детали вашего приёма пищи">

    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <Border x:Name="Inner" Background="{TemplateBinding Background}" CornerRadius="10">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Mouse.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Inner"
                                            Storyboard.TargetProperty="RenderTransform.Y"
                                            To="-3" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Mouse.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Inner"
                                            Storyboard.TargetProperty="RenderTransform.Y"
                                            To="0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock x:Name="TitleText"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryText}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="FoodsList"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBackground}"
                                CornerRadius="10"
                                Margin="0,5"
                                Padding="12">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               FontSize="15"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock FontSize="12"
                                               Foreground="{DynamicResource SecondaryText}">
                                        <Run Text="{Binding Weight, StringFormat={}{0:F0} г}"/>
                                        <Run Text=" • "/>
                                        <Run Text="{Binding Calories, StringFormat={}{0:F0} ккал}"/>
                                    </TextBlock>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="✏️"
                                        Width="36" Height="36"
                                        Margin="0,0,8,0"
                                        Click="EditButton_Click"
                                        Style="{StaticResource IconButton}"
                                        Background="{DynamicResource EditBackground}"
                                        ToolTip="Редактировать"
                                        Tag="{Binding}"/>

                                <Button Grid.Column="2"
                                        Content="🗑️"
                                        Width="36" Height="36"
                                        Click="DeleteButton_Click"
                                        Style="{StaticResource IconButton}"
                                        Background="{DynamicResource DeleteBackground}"
                                        ToolTip="Удалить"
                                        Tag="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <TextBlock x:Name="SummaryText"
                   Grid.Row="2"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Right"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{DynamicResource SecondaryText}"/>
    </Grid>
</Window>
