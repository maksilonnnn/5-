<Application x:Class="calcaot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:calcaot.Interface.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <local:ProgressToArcConverter x:Key="ProgressToArcConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Interface/Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
