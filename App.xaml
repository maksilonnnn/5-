<Application x:Class="CalorieApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackground"    Color="#F5F5F7"/>
        <SolidColorBrush x:Key="CardBackground"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryText"      Color="#1C1C1E"/>
        <SolidColorBrush x:Key="SecondaryText"    Color="#8E8E93"/>
        <SolidColorBrush x:Key="IconBackground"   Color="#EFF4FF"/>
        <SolidColorBrush x:Key="DeleteBackground" Color="#FFF0F0"/>
        <SolidColorBrush x:Key="EditBackground"   Color="#EFF4FF"/>
        <SolidColorBrush x:Key="InputBorder"      Color="#E0E0E0"/>
    </Application.Resources>
</Application>