<Window x:Class="CalorieApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calorie Tracker MVVM" Height="600" Width="800" Background="#F5F5F7">
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/> <ColumnDefinition Width="*"/>   </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Top">
            <TextBlock Text="Добавить блюдо" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock Text="Название:"/>
            <TextBox x:Name="NameInput" Margin="0,5,0,10" Padding="5"/>
            
            <TextBlock Text="Вес (г):"/>
            <TextBox x:Name="WeightInput" Margin="0,5,0,10" Padding="5"/>
            
            <TextBlock Text="Калории на 100г:"/>
            <TextBox x:Name="CalInput" Margin="0,5,0,10" Padding="5"/>

            <TextBlock Text="Прием пищи:"/>
            <ComboBox x:Name="MealCombo" Margin="0,5,0,20" SelectedIndex="0">
                <ComboBoxItem Content="Завтрак"/>
                <ComboBoxItem Content="Обед"/>
                <ComboBoxItem Content="Ужин"/>
                <ComboBoxItem Content="Перекус"/>
            </ComboBox>

            <Button Content="Добавить" Click="AddBtn_Click" 
                    Background="#007AFF" Foreground="White" Height="40" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Column="1" Margin="30,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
                <TextBlock Text="Осталось калорий" Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding RemainingCalories, StringFormat={}{0:F0}}" 
                           FontSize="64" FontWeight="Light" Foreground="#007AFF"/>
            </StackPanel>

            <ListBox Grid.Row="1" ItemsSource="{Binding ConsumedFoods}" 
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Margin="0,5" Padding="15">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="{Binding MealType}" Foreground="Gray" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Calories, StringFormat={}{0} ккал}" 
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           FontSize="16" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
